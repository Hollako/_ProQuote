# ProQuote secrets — TEMPLATE (safe to share; contains no real credentials).
# Copy this to ".streamlit/secrets.toml" and paste your real Neon URL THERE.
# secrets.toml is gitignored; this .example file is NOT — never put a real
# credential in this file.
#
# Use the DIRECT (non-pooled) connection string from Neon's Connect dialog:
#   - turn OFF "Connection pooling" in the dialog
#   - the host has NO "-pooler" segment
#   - keep the "?sslmode=require" at the end
# The app maintains its own connection pool, so the direct endpoint is the
# safest choice (avoids PgBouncer prepared-statement issues with psycopg3).

DATABASE_URL = "postgresql://USER:PASSWORD@ep-xxxxxxxx.eu-central-1.aws.neon.tech/proquote?sslmode=require"

# Optional: only if you want migrations to use a different URL than the app.
# Defaults to DATABASE_URL when omitted.
# POSTGRES_MIGRATION_URL = "postgresql://USER:PASSWORD@ep-xxxxxxxx.eu-central-1.aws.neon.tech/proquote?sslmode=require"
